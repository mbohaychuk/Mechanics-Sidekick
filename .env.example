# Mechanics Sidekick — configuration. Copy to .env and set at least OPENAI_API_KEY.
# Defaults live in app/config.py; every value here can also be set as an environment variable.

# ── LLM provider ────────────────────────────────────────────────────────────
# v1 default is OpenAI for chat AND embeddings. Set EMBED_PROVIDER/LLM_PROVIDER to
# "ollama" for a fully-local setup (then OPENAI_API_KEY is not required).
LLM_PROVIDER=openai
EMBED_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Local (Ollama) provider — only used when *_PROVIDER=ollama ───────────────
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=llama3.2:3b
CONTEXT_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text

# ── Retrieval / RAG ─────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_CHUNKS=5
RECENT_MESSAGES=6
MAX_AGENT_ITERS=6

# ── API server + frontend ───────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGIN=http://localhost:5173
SPA_DIST_DIR=frontend/dist
MAX_UPLOAD_BYTES=104857600

# ── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=./data/app.db
DOCS_DIR=./data/documents

# ── Live OBD tools (obd-mcp) ────────────────────────────────────────────────
OBD_MCP_ENABLED=false
OBD_MCP_DIR=/home/you/repos/OBD-II-MCP-Server
OBD_PORT=socket://localhost:35000
OBD_TOOL_DENYLIST=ping,record_session
MCP_CALL_TIMEOUT_S=30.0
MCP_START_TIMEOUT_S=20.0

# ── Web search (Tavily) ─────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=true
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# ── Live telemetry ──────────────────────────────────────────────────────────
LIVE_SAMPLE_HZ=1.0
LIVE_MIN_INTERVAL_S=0.25
LIVE_MAX_PIDS=16
LIVE_SUBSCRIBER_QUEUE=2
LIVE_RECORDER_BATCH=20

# ── Diagnostic copilot ──────────────────────────────────────────────────────
DIAG_ENABLED=true
DIAG_PROTOCOL=default
DIAG_COMMENTARY_INTERVAL_S=5.0
DIAG_COMMENTARY_MAX_TOKENS=160
DIAG_COMMENTARY_WINDOW_S=15.0
DIAG_COMMENTARY_MAX_POINTS=20
DIAG_MAX_ADHOC_STEPS=2
DIAG_FUEL_TRIM_PCT=10.0
DIAG_COOLANT_MAX_C=105.0
DIAG_IDLE_RPM_JITTER=150.0
DIAG_MANUAL_MIN_SCORE=0.35
DIAG_REPORT_RECENT_LIMIT=3
DIAG_REPORT_MAX_TOKENS=600
